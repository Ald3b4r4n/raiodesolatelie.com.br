rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && "admin" in request.auth.token && request.auth.token.admin == true;
    }

    function ownsUserDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function activeResource() {
      return resource.data.status == "active";
    }

    match /products/{productId} {
      allow read: if activeResource() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if activeResource() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /productVariants/{variantId} {
      allow read: if activeResource() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create, delete: if false;
      allow update: if isAdmin();
    }

    match /customerProfiles/{userId} {
      allow read, create, update: if ownsUserDocument(userId) || isAdmin();
      allow delete: if false;
    }

    match /paymentSessions/{sessionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.customerId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /coupons/{couponId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "approved" || isAdmin() ||
        (signedIn() && resource.data.customerId == request.auth.uid);
      allow create: if signedIn() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.status == "pending" &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update, delete: if isAdmin();
    }

    match /userRoles/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
