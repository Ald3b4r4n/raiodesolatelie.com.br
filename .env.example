# Configuração pública do cliente Firebase.
# A configuração web pública do Firebase não é segredo, mas deve ser revisada.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Configuração Firebase Admin somente para servidor.
# Nunca exponha estes valores com prefixo NEXT_PUBLIC_.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Contato e redes sociais da loja.
# TODO: preencher quando a cliente informar o WhatsApp oficial.
STORE_WHATSAPP_PHONE=
# TODO: preencher quando os links oficiais forem confirmados.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Provedores do MVP ficam mockados até credenciais reais serem aprovadas.
PAYMENT_PROVIDER=mock
SHIPPING_PROVIDER=mock
