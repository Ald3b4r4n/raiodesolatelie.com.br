# Firebase public client configuration.
# Public Firebase web config is not a secret, but values still must be reviewed.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only Firebase Admin configuration.
# Never expose these with NEXT_PUBLIC_.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Store contact and social links.
STORE_WHATSAPP_PHONE=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=

# MVP providers stay mocked until real credentials/providers are approved.
PAYMENT_PROVIDER=mock
SHIPPING_PROVIDER=mock
