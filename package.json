{
  "name": "raiodesolatelie-com-br",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:rules": "firebase emulators:exec --project demo-raiodesolatelie --only firestore,storage \"pnpm exec vitest run --config vitest.rules.config.ts\"",
    "test:e2e": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/accessibility",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run tests/unit/smoke.test.ts tests/unit/security/env.test.ts tests/unit/components/bootstrap-page.test.tsx",
    "firebase:emulators": "firebase emulators:start --project demo-raiodesolatelie --only auth,firestore,storage",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "firebase-tools": "^14.24.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
